# ── Drone Classify Atlas · Backend Environment ─────────────────────────────
# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:   mongodb://localhost:27017/drone_classify_atlas
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/drone_classify_atlas
MONGO_URI=mongodb://localhost:27017/drone_classify_atlas

# Server port
PORT=3000

# Absolute path to the exported TensorFlow SavedModel directory
# Generated by drone_training.ipynb → models/drone_classifier_tf/
MODEL_PATH=../models/drone_classifier_tf

# Model accuracy to display in the UI (set after training)
MODEL_ACCURACY=93.2

# CORS — set to your deployed frontend URL in production
# FRONTEND_ORIGIN=https://your-domain.com
